# ============================================================
# CLIENT — React / Vite (TypeScript)
# ============================================================

# Dependencies
client/node_modules/

# Build output
client/dist/
client/dist-ssr/

# Vite cache
client/.vite/

# TypeScript build info
client/*.tsbuildinfo

# Local env files
client/.env
client/.env.local
client/.env.*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ============================================================
# SERVER — Python / FastAPI
# ============================================================

# Virtual environment
server/.venv/
server/venv/
server/env/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# Database (local SQLite file — never commit this)
server/*.sqlite3
server/*.db

# Uploaded resume files (potentially large & sensitive)
server/uploads/

# Temporary / debug output files
server/temp_*.txt
server/create_res.json
server/output_del.json

# Local env files
server/.env
server/.env.local

# ============================================================
# EDITOR & OS
# ============================================================

# VSCode
.vscode/*
!.vscode/extensions.json

# JetBrains IDEs
.idea/

# macOS
.DS_Store

# Windows
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# Linux
*~
